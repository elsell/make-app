type __DOMAIN__Authenticator struct{}

var err__DOMAIN_GO_NAME__AuthenticationDependency = errors.New("authentication dependency unavailable")

func (__DOMAIN__Authenticator) Authenticate(_ context.Context, authorization string) (ports.Principal, error) {
	if authorization == "Bearer unavailable" {
		return ports.Principal{}, err__DOMAIN_GO_NAME__AuthenticationDependency
	}
	if authorization != "Bearer valid" {
