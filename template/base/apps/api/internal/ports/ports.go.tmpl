package ports

import (
	"context"
	"errors"
	"__MODULE__/apps/api/internal/domain/identity"
)

var ErrNotFound = errors.New("not found")

type Claims struct { Issuer, Subject, Email, DisplayName string }
type Authenticator interface { Authenticate(context.Context, string) (Claims, error) }
type Users interface { ResolveOrCreate(context.Context, Claims) (identity.User, error) }
type Authorizer interface { WriteOwner(context.Context, string, string, string) error; DeleteOwner(context.Context, string, string, string) error; Check(context.Context, string, string, string, string) (bool, error) }
type Resource struct { ID, Domain, OwnerUserID, Name string }
type AuthorizationOperation string
const (
	AuthorizationTouch AuthorizationOperation = "touch"
	AuthorizationDelete AuthorizationOperation = "delete"
)
type AuthorizationChange struct { ID, ResourceType, ResourceID, Relation, SubjectType, SubjectID string; Operation AuthorizationOperation; Attempts int }
type Resources interface { CreateResource(context.Context, Resource, AuthorizationChange) error; ListResources(context.Context, string, string) ([]Resource,error); GetResource(context.Context, string, string) (Resource,error); UpdateResource(context.Context, string, string, string) (Resource,error); DeleteResource(context.Context, string, string, AuthorizationChange) error }
type AuthorizationOutbox interface { PendingAuthorizationChanges(context.Context, int) ([]AuthorizationChange,error); CompleteAuthorizationChange(context.Context,string)error; FailAuthorizationChange(context.Context,string)error }
