package app

import (
	"__MODULE__/apps/api/internal/domain/identity"
	"__MODULE__/apps/api/internal/ports"
	"context"
	"crypto/hmac"
	"crypto/sha256"
	"encoding/base64"
	"encoding/json"
	"errors"
	"github.com/google/uuid"
	"time"
)

func newID() string { return uuid.NewString() }

type App struct {
	Auth                ports.Authenticator
	Users               ports.Users
	Authorizer          ports.Authorizer
	Resources           ports.Resources
	AuthorizationOutbox ports.AuthorizationOutbox
	AuthorizationSerializer ports.AuthorizationSerializer
	Clock               ports.Clock
	Dependencies        []ports.HealthChecker
	CursorSigningKey    []byte
}

var ErrUnauthenticated = errors.New("unauthenticated")
var ErrForbidden = errors.New("forbidden")

func (a App) Health(ctx context.Context) error {
	for _, dependency := range a.Dependencies { if err := dependency.Health(ctx); err != nil { return err } }
	return nil
}

func (a App) CurrentUser(ctx context.Context, authorization string) (identity.User, error) {
	claims, err := a.Auth.Authenticate(ctx, authorization)
	if err != nil {
		return identity.User{}, ErrUnauthenticated
	}
	return a.Users.ResolveOrCreate(ctx, claims)
}
func (a App) CreateResource(ctx context.Context, authorization, domain, name string) (ports.Resource, error) {
	u, err := a.CurrentUser(ctx, authorization)
	if err != nil {
		return ports.Resource{}, err
	}
	r := ports.Resource{ID: newID(), Domain: domain, OwnerUserID: u.ID, Name: name, CreatedAt: a.Clock.Now().UTC()}
	worker := newID()
	now := a.Clock.Now().UTC()
	change := ports.AuthorizationChange{ID: newID(), ResourceType: "resource", ResourceID: domain + "/" + r.ID, Relation: "owner", SubjectType: "user", SubjectID: u.ID, Operation: ports.AuthorizationTouch, LockedBy: worker, LockedUntil: now.Add(30*time.Second)}
	if err = a.Resources.CreateResource(ctx, r, change); err != nil {
		return ports.Resource{}, err
	}
	if err = a.reconcileClaimedAuthorizationChange(ctx, change, worker); err != nil {
		return ports.Resource{}, err
	}
	return r, nil
}

type ResourcePage struct {
	Resources  []ports.Resource
	NextCursor string
}
type cursorPayload struct { Version int `json:"v"`; Owner, Domain, AfterID string; AfterCreated, Snapshot time.Time }

func (a App) ListResources(ctx context.Context, authorization, domain, cursor string, limit int) (ResourcePage, error) {
	u, err := a.CurrentUser(ctx, authorization)
	if err != nil {
		return ResourcePage{}, err
	}
	if limit == 0 {
		limit = 50
	}
	if limit < 1 || limit > 100 {
		return ResourcePage{}, ports.ErrInvalidArgument
	}
	request := ports.PageRequest{Limit: limit, Snapshot: a.Clock.Now().UTC()}
	if cursor != "" {
		payload, decodeErr := a.decodeCursor(cursor)
		if decodeErr != nil || payload.Owner != u.ID || payload.Domain != domain { return ResourcePage{}, ports.ErrInvalidArgument }
		request.AfterID, request.AfterCreated, request.Snapshot = payload.AfterID, payload.AfterCreated, payload.Snapshot
	}
	page, err := a.Resources.ListResources(ctx, domain, u.ID, request)
	if err != nil {
		return ResourcePage{}, err
	}
	result := ResourcePage{Resources: page.Resources}
	if page.HasMore && len(page.Resources) > 0 {
		last := page.Resources[len(page.Resources)-1]
		result.NextCursor, err = a.encodeCursor(cursorPayload{Version: 1, Owner: u.ID, Domain: domain, AfterID: last.ID, AfterCreated: last.CreatedAt, Snapshot: request.Snapshot})
		if err != nil { return ResourcePage{}, err }
	}
	return result, nil
}
func (a App) encodeCursor(payload cursorPayload) (string, error) { if len(a.CursorSigningKey)<32{return "",errors.New("cursor signing key is required")}; body,err:=json.Marshal(payload);if err!=nil{return "",err};mac:=hmac.New(sha256.New,a.CursorSigningKey);_,_=mac.Write(body);return base64.RawURLEncoding.EncodeToString(append(body,mac.Sum(nil)...)),nil }
func (a App) decodeCursor(value string) (cursorPayload,error) { var payload cursorPayload;if len(a.CursorSigningKey)<32{return payload,ports.ErrInvalidArgument};raw,err:=base64.RawURLEncoding.DecodeString(value);if err!=nil||len(raw)<=sha256.Size{return payload,ports.ErrInvalidArgument};body,signature:=raw[:len(raw)-sha256.Size],raw[len(raw)-sha256.Size:];mac:=hmac.New(sha256.New,a.CursorSigningKey);_,_=mac.Write(body);if !hmac.Equal(signature,mac.Sum(nil)){return payload,ports.ErrInvalidArgument};if err=json.Unmarshal(body,&payload);err!=nil||payload.Version!=1||payload.Owner==""||payload.Domain==""||payload.AfterID==""||payload.AfterCreated.IsZero()||payload.Snapshot.IsZero()||payload.AfterCreated.After(payload.Snapshot){return cursorPayload{},ports.ErrInvalidArgument};return payload,nil }
func (a App) GetResource(ctx context.Context, authorization, domain, id string) (ports.Resource, error) {
	u, err := a.CurrentUser(ctx, authorization)
	if err != nil {
		return ports.Resource{}, err
	}
	ok, err := a.Authorizer.Check(ctx, "resource", domain+"/"+id, "view", u.ID)
	if err != nil {
		return ports.Resource{}, err
	}
	if !ok {
		return ports.Resource{}, ErrForbidden
	}
	return a.Resources.GetResource(ctx, domain, id)
}
func (a App) UpdateResource(ctx context.Context, authorization, domain, id, name string) (ports.Resource, error) {
	u, err := a.CurrentUser(ctx, authorization)
	if err != nil {
		return ports.Resource{}, err
	}
	ok, err := a.Authorizer.Check(ctx, "resource", domain+"/"+id, "update", u.ID)
	if err != nil {
		return ports.Resource{}, err
	}
	if !ok {
		return ports.Resource{}, ErrForbidden
	}
	return a.Resources.UpdateResource(ctx, domain, id, name)
}
func (a App) DeleteResource(ctx context.Context, authorization, domain, id string) error {
	u, err := a.CurrentUser(ctx, authorization)
	if err != nil {
		return err
	}
	ok, err := a.Authorizer.Check(ctx, "resource", domain+"/"+id, "delete", u.ID)
	if err != nil {
		return err
	}
	if !ok {
		return ErrForbidden
	}
	worker := newID()
	now := a.Clock.Now().UTC()
	change := ports.AuthorizationChange{ID: newID(), ResourceType: "resource", ResourceID: domain + "/" + id, Relation: "owner", SubjectType: "user", SubjectID: u.ID, Operation: ports.AuthorizationDelete, LockedBy: worker, LockedUntil: now.Add(30*time.Second)}
	if err = a.Resources.DeleteResource(ctx, domain, id, change); err != nil {
		return err
	}
	return a.reconcileClaimedAuthorizationChange(ctx, change, worker)
}
func (a App) ReconcileAuthorization(ctx context.Context, worker string, limit int) error {
	now := a.Clock.Now().UTC()
	changes, err := a.AuthorizationOutbox.ClaimAuthorizationChanges(ctx, worker, now, 30*time.Second, limit)
	if err != nil {
		return err
	}
	var failures []error
	for _, c := range changes {
		if err := a.reconcileClaimedAuthorizationChange(ctx, c, worker); err != nil {
			failures = append(failures, err)
		}
	}
	return errors.Join(failures...)
}
func (a App) ReconcileAuthorizationChange(ctx context.Context, id, worker string) error {
	change, err := a.AuthorizationOutbox.ClaimAuthorizationChange(ctx, id, worker, a.Clock.Now().UTC(), 30*time.Second)
	if err != nil {
		return err
	}
	return a.reconcileClaimedAuthorizationChange(ctx, change, worker)
}
func (a App) reconcileClaimedAuthorizationChange(ctx context.Context, change ports.AuthorizationChange, worker string) error {
	if a.AuthorizationSerializer == nil {
		return errors.New("authorization serializer is required")
	}
	err := a.AuthorizationSerializer.WithinResource(ctx, change.ResourceType, change.ResourceID, func(locked context.Context) error {
	switch change.Operation {
	case ports.AuthorizationTouch:
		return a.Authorizer.WriteOwner(locked, change.ResourceType, change.ResourceID, change.SubjectID)
	case ports.AuthorizationDelete:
		return a.Authorizer.DeleteOwner(locked, change.ResourceType, change.ResourceID, change.SubjectID)
	default:
		return errors.New("unsupported authorization operation")
	}
	})
	if err != nil {
		_ = a.AuthorizationOutbox.FailAuthorizationChange(ctx, change.ID, worker, a.Clock.Now().UTC())
		return err
	}
	return a.AuthorizationOutbox.CompleteAuthorizationChange(ctx, change.ID, worker, a.Clock.Now().UTC())
}
