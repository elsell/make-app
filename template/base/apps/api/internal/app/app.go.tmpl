package app

import (
	"context"
	"errors"
	"__MODULE__/apps/api/internal/domain/identity"
	"__MODULE__/apps/api/internal/ports"
	"github.com/google/uuid"
)
func newID()string{return uuid.NewString()}

type App struct { Auth ports.Authenticator; Users ports.Users; Authorizer ports.Authorizer; Resources ports.Resources }
func (a App) CurrentUser(ctx context.Context, authorization string) (identity.User,error) { claims,err:=a.Auth.Authenticate(ctx,authorization); if err!=nil{return identity.User{},err}; return a.Users.ResolveOrCreate(ctx,claims) }
var ErrForbidden = errors.New("forbidden")
func(a App)CreateResource(ctx context.Context,authorization,name string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};r:=ports.Resource{ID:newID(),OwnerUserID:u.ID,Name:name};if err=a.Resources.CreateResource(ctx,r);err!=nil{return ports.Resource{},err};if err=a.Authorizer.WriteOwner(ctx,"example",r.ID,u.ID);err!=nil{return ports.Resource{},err};return r,nil}
func(a App)ListResources(ctx context.Context,authorization string)([]ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return nil,err};return a.Resources.ListResources(ctx,u.ID)}
func(a App)GetResource(ctx context.Context,authorization,id string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};ok,err:=a.Authorizer.Check(ctx,"example",id,"view",u.ID);if err!=nil||!ok{return ports.Resource{},ErrForbidden};return a.Resources.GetResource(ctx,id)}
