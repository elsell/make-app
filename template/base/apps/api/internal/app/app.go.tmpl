package app

import (
	"context"
	"errors"
	"__MODULE__/apps/api/internal/domain/identity"
	"__MODULE__/apps/api/internal/ports"
	"github.com/google/uuid"
)
func newID()string{return uuid.NewString()}

type App struct { Auth ports.Authenticator; Users ports.Users; Authorizer ports.Authorizer; Resources ports.Resources; AuthorizationOutbox ports.AuthorizationOutbox }
var ErrUnauthenticated = errors.New("unauthenticated")
var ErrForbidden = errors.New("forbidden")
func (a App) CurrentUser(ctx context.Context, authorization string) (identity.User,error) { claims,err:=a.Auth.Authenticate(ctx,authorization); if err!=nil{return identity.User{},ErrUnauthenticated}; return a.Users.ResolveOrCreate(ctx,claims) }
func(a App)CreateResource(ctx context.Context,authorization,domain,name string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};r:=ports.Resource{ID:newID(),Domain:domain,OwnerUserID:u.ID,Name:name};change:=ports.AuthorizationChange{ID:newID(),ResourceType:"resource",ResourceID:domain+"/"+r.ID,Relation:"owner",SubjectType:"user",SubjectID:u.ID,Operation:ports.AuthorizationTouch};if err=a.Resources.CreateResource(ctx,r,change);err!=nil{return ports.Resource{},err};_ = a.ReconcileAuthorization(ctx,1);return r,nil}
func(a App)ListResources(ctx context.Context,authorization,domain string)([]ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return nil,err};return a.Resources.ListResources(ctx,domain,u.ID)}
func(a App)GetResource(ctx context.Context,authorization,domain,id string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};ok,err:=a.Authorizer.Check(ctx,"resource",domain+"/"+id,"view",u.ID);if err!=nil{return ports.Resource{},err};if !ok{return ports.Resource{},ErrForbidden};return a.Resources.GetResource(ctx,domain,id)}
func(a App)UpdateResource(ctx context.Context,authorization,domain,id,name string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};ok,err:=a.Authorizer.Check(ctx,"resource",domain+"/"+id,"update",u.ID);if err!=nil{return ports.Resource{},err};if !ok{return ports.Resource{},ErrForbidden};return a.Resources.UpdateResource(ctx,domain,id,name)}
func(a App)DeleteResource(ctx context.Context,authorization,domain,id string)error{u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return err};ok,err:=a.Authorizer.Check(ctx,"resource",domain+"/"+id,"delete",u.ID);if err!=nil{return err};if !ok{return ErrForbidden};change:=ports.AuthorizationChange{ID:newID(),ResourceType:"resource",ResourceID:domain+"/"+id,Relation:"owner",SubjectType:"user",SubjectID:u.ID,Operation:ports.AuthorizationDelete};if err=a.Resources.DeleteResource(ctx,domain,id,change);err!=nil{return err};_ = a.ReconcileAuthorization(ctx,1);return nil}
func(a App)ReconcileAuthorization(ctx context.Context,limit int)error{changes,err:=a.AuthorizationOutbox.PendingAuthorizationChanges(ctx,limit);if err!=nil{return err};for _,c:=range changes{switch c.Operation{case ports.AuthorizationTouch:err=a.Authorizer.WriteOwner(ctx,c.ResourceType,c.ResourceID,c.SubjectID);case ports.AuthorizationDelete:err=a.Authorizer.DeleteOwner(ctx,c.ResourceType,c.ResourceID,c.SubjectID);default:err=errors.New("unsupported authorization operation")};if err!=nil{_ = a.AuthorizationOutbox.FailAuthorizationChange(ctx,c.ID);return err};if err:=a.AuthorizationOutbox.CompleteAuthorizationChange(ctx,c.ID);err!=nil{return err}};return nil}
