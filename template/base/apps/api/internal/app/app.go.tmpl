package app

import (
	"context"
	"errors"
	"__MODULE__/apps/api/internal/domain/identity"
	"__MODULE__/apps/api/internal/ports"
	"github.com/google/uuid"
)
func newID()string{return uuid.NewString()}

type App struct { Auth ports.Authenticator; Users ports.Users; Authorizer ports.Authorizer; Resources ports.Resources; AuthorizationOutbox ports.AuthorizationOutbox }
func (a App) CurrentUser(ctx context.Context, authorization string) (identity.User,error) { claims,err:=a.Auth.Authenticate(ctx,authorization); if err!=nil{return identity.User{},err}; return a.Users.ResolveOrCreate(ctx,claims) }
var ErrForbidden = errors.New("forbidden")
func(a App)CreateResource(ctx context.Context,authorization,domain,name string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};r:=ports.Resource{ID:newID(),Domain:domain,OwnerUserID:u.ID,Name:name};change:=ports.AuthorizationChange{ID:newID(),ResourceType:"resource",ResourceID:domain+":"+r.ID,Relation:"owner",SubjectType:"user",SubjectID:u.ID};if err=a.Resources.CreateResource(ctx,r,change);err!=nil{return ports.Resource{},err};_ = a.ReconcileAuthorization(ctx,1);return r,nil}
func(a App)ListResources(ctx context.Context,authorization,domain string)([]ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return nil,err};return a.Resources.ListResources(ctx,domain,u.ID)}
func(a App)GetResource(ctx context.Context,authorization,domain,id string)(ports.Resource,error){u,err:=a.CurrentUser(ctx,authorization);if err!=nil{return ports.Resource{},err};ok,err:=a.Authorizer.Check(ctx,"resource",domain+":"+id,"view",u.ID);if err!=nil||!ok{return ports.Resource{},ErrForbidden};return a.Resources.GetResource(ctx,domain,id)}
func(a App)ReconcileAuthorization(ctx context.Context,limit int)error{changes,err:=a.AuthorizationOutbox.PendingAuthorizationChanges(ctx,limit);if err!=nil{return err};for _,c:=range changes{if err:=a.Authorizer.WriteOwner(ctx,c.ResourceType,c.ResourceID,c.SubjectID);err!=nil{_ = a.AuthorizationOutbox.FailAuthorizationChange(ctx,c.ID);continue};if err:=a.AuthorizationOutbox.CompleteAuthorizationChange(ctx,c.ID);err!=nil{return err}};return nil}
