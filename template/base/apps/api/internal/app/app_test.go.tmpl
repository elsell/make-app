type blockingSerializer struct {
	entered chan struct{}
	release chan struct{}
	once    sync.Once
}

func (s *blockingSerializer) WithinResource(ctx context.Context, _, _ string, fn func(context.Context) error) error {
	s.once.Do(func() {
		close(s.entered)
		<-s.release
	})
	return fn(ctx)
}

