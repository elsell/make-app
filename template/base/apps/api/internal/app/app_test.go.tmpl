package app

import("context";"errors";"testing";"__MODULE__/apps/api/internal/domain/identity";"__MODULE__/apps/api/internal/ports")
type fakeAuth struct{claims ports.Claims;err error};func(f fakeAuth)Authenticate(context.Context,string)(ports.Claims,error){return f.claims,f.err}
type fakeUsers struct{user identity.User};func(f fakeUsers)ResolveOrCreate(context.Context,ports.Claims)(identity.User,error){return f.user,nil}
type fakeAuthz struct{allowed bool;err error};func(f fakeAuthz)WriteOwner(context.Context,string,string,string)error{return f.err};func(f fakeAuthz)Check(context.Context,string,string,string,string)(bool,error){return f.allowed,f.err}
type fakeResources struct{resource ports.Resource};func(f fakeResources)CreateResource(context.Context,ports.Resource,ports.AuthorizationChange)error{return nil};func(f fakeResources)ListResources(context.Context,string,string)([]ports.Resource,error){return nil,nil};func(f fakeResources)GetResource(context.Context,string,string)(ports.Resource,error){return f.resource,nil}
type fakeOutbox struct{changes []ports.AuthorizationChange;completed *bool;failed *bool};func(f fakeOutbox)PendingAuthorizationChanges(context.Context,int)([]ports.AuthorizationChange,error){return f.changes,nil};func(f fakeOutbox)CompleteAuthorizationChange(context.Context,string)error{if f.completed!=nil{*f.completed=true};return nil};func(f fakeOutbox)FailAuthorizationChange(context.Context,string)error{if f.failed!=nil{*f.failed=true};return nil}
func TestGetResourceFailsClosed(t *testing.T){a:=App{Auth:fakeAuth{},Users:fakeUsers{identity.User{ID:"attacker"}},Authorizer:fakeAuthz{allowed:false},Resources:fakeResources{ports.Resource{ID:"secret",OwnerUserID:"owner"}}};_,err:=a.GetResource(context.Background(),"Bearer token","example","secret");if !errors.Is(err,ErrForbidden){t.Fatalf("expected forbidden, got %v",err)}}
func TestGetResourceAllowsOwner(t *testing.T){r:=ports.Resource{ID:"mine",Domain:"example",OwnerUserID:"owner"};a:=App{Auth:fakeAuth{},Users:fakeUsers{identity.User{ID:"owner"}},Authorizer:fakeAuthz{allowed:true},Resources:fakeResources{r}};got,err:=a.GetResource(context.Background(),"Bearer token","example","mine");if err!=nil||got.ID!="mine"{t.Fatalf("unexpected result: %#v %v",got,err)}}
func TestReconcileKeepsFailedAuthorizationChangePending(t *testing.T){failed:=false;a:=App{Authorizer:fakeAuthz{err:errors.New("spicedb unavailable")},AuthorizationOutbox:fakeOutbox{changes:[]ports.AuthorizationChange{{ID:"change",ResourceID:"resource",SubjectID:"user"}},failed:&failed}};if err:=a.ReconcileAuthorization(context.Background(),10);err!=nil{t.Fatal(err)};if !failed{t.Fatal("expected failed attempt to remain retryable")}}
func TestReconcileCompletesSuccessfulAuthorizationChange(t *testing.T){completed:=false;a:=App{Authorizer:fakeAuthz{},AuthorizationOutbox:fakeOutbox{changes:[]ports.AuthorizationChange{{ID:"change",ResourceID:"resource",SubjectID:"user"}},completed:&completed}};if err:=a.ReconcileAuthorization(context.Background(),10);err!=nil{t.Fatal(err)};if !completed{t.Fatal("expected completed authorization change")}}
