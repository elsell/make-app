package app

import("context";"errors";"testing";"__MODULE__/apps/api/internal/domain/identity";"__MODULE__/apps/api/internal/ports")
type fakeAuth struct{claims ports.Claims;err error};func(f fakeAuth)Authenticate(context.Context,string)(ports.Claims,error){return f.claims,f.err}
type fakeUsers struct{user identity.User;err error};func(f fakeUsers)ResolveOrCreate(context.Context,ports.Claims)(identity.User,error){return f.user,f.err}
type fakeAuthz struct{allowed bool;err error;deleted *bool};func(f fakeAuthz)WriteOwner(context.Context,string,string,string)error{return f.err};func(f fakeAuthz)DeleteOwner(context.Context,string,string,string)error{if f.deleted!=nil{*f.deleted=true};return f.err};func(f fakeAuthz)Check(context.Context,string,string,string,string)(bool,error){return f.allowed,f.err}
type fakeResources struct{resource ports.Resource;deletedChange *ports.AuthorizationChange};func(f fakeResources)CreateResource(context.Context,ports.Resource,ports.AuthorizationChange)error{return nil};func(f fakeResources)ListResources(context.Context,string,string)([]ports.Resource,error){return nil,nil};func(f fakeResources)GetResource(context.Context,string,string)(ports.Resource,error){return f.resource,nil};func(f fakeResources)UpdateResource(_ context.Context,_,_,name string)(ports.Resource,error){r:=f.resource;r.Name=name;return r,nil};func(f fakeResources)DeleteResource(_ context.Context,_,_ string,c ports.AuthorizationChange)error{if f.deletedChange!=nil{*f.deletedChange=c};return nil}
type fakeOutbox struct{changes []ports.AuthorizationChange;completed *bool;failed *bool};func(f fakeOutbox)PendingAuthorizationChanges(context.Context,int)([]ports.AuthorizationChange,error){return f.changes,nil};func(f fakeOutbox)CompleteAuthorizationChange(context.Context,string)error{if f.completed!=nil{*f.completed=true};return nil};func(f fakeOutbox)FailAuthorizationChange(context.Context,string)error{if f.failed!=nil{*f.failed=true};return nil}
func TestGetResourceFailsClosed(t *testing.T){a:=App{Auth:fakeAuth{},Users:fakeUsers{user:identity.User{ID:"attacker"}},Authorizer:fakeAuthz{allowed:false},Resources:fakeResources{resource:ports.Resource{ID:"secret",OwnerUserID:"owner"}}};_,err:=a.GetResource(context.Background(),"Bearer token","example","secret");if !errors.Is(err,ErrForbidden){t.Fatalf("expected forbidden, got %v",err)}}
func TestGetResourceAllowsOwner(t *testing.T){r:=ports.Resource{ID:"mine",Domain:"example",OwnerUserID:"owner"};a:=App{Auth:fakeAuth{},Users:fakeUsers{user:identity.User{ID:"owner"}},Authorizer:fakeAuthz{allowed:true},Resources:fakeResources{resource:r}};got,err:=a.GetResource(context.Background(),"Bearer token","example","mine");if err!=nil||got.ID!="mine"{t.Fatalf("unexpected result: %#v %v",got,err)}}
func TestReconcileKeepsFailedAuthorizationChangePending(t *testing.T){failed:=false;a:=App{Authorizer:fakeAuthz{err:errors.New("spicedb unavailable")},AuthorizationOutbox:fakeOutbox{changes:[]ports.AuthorizationChange{{ID:"change",ResourceID:"resource",SubjectID:"user",Operation:ports.AuthorizationTouch}},failed:&failed}};if err:=a.ReconcileAuthorization(context.Background(),10);err==nil{t.Fatal("expected dependency error")};if !failed{t.Fatal("expected failed attempt to remain retryable")}}
func TestReconcileCompletesSuccessfulAuthorizationChange(t *testing.T){completed:=false;a:=App{Authorizer:fakeAuthz{},AuthorizationOutbox:fakeOutbox{changes:[]ports.AuthorizationChange{{ID:"change",ResourceID:"resource",SubjectID:"user",Operation:ports.AuthorizationTouch}},completed:&completed}};if err:=a.ReconcileAuthorization(context.Background(),10);err!=nil{t.Fatal(err)};if !completed{t.Fatal("expected completed authorization change")}}
func TestCurrentUserClassifiesOnlyTokenFailuresAsUnauthenticated(t *testing.T){a:=App{Auth:fakeAuth{err:errors.New("bad token")},Users:fakeUsers{}};_,err:=a.CurrentUser(context.Background(),"Bearer bad");if !errors.Is(err,ErrUnauthenticated){t.Fatalf("expected unauthenticated, got %v",err)};databaseErr:=errors.New("database unavailable");a=App{Auth:fakeAuth{},Users:fakeUsers{err:databaseErr}};_,err=a.CurrentUser(context.Background(),"Bearer valid");if !errors.Is(err,databaseErr)||errors.Is(err,ErrUnauthenticated){t.Fatalf("persistence error was misclassified: %v",err)}}
func TestGetResourcePreservesAuthorizationDependencyFailure(t *testing.T){dependencyErr:=errors.New("spicedb unavailable");a:=App{Auth:fakeAuth{},Users:fakeUsers{user:identity.User{ID:"owner"}},Authorizer:fakeAuthz{err:dependencyErr}};_,err:=a.GetResource(context.Background(),"Bearer valid","example","id");if !errors.Is(err,dependencyErr)||errors.Is(err,ErrForbidden){t.Fatalf("dependency failure was concealed as denial: %v",err)}}
func TestDeleteResourceQueuesAuthorizationCleanup(t *testing.T){var change ports.AuthorizationChange;deleted:=false;a:=App{Auth:fakeAuth{},Users:fakeUsers{user:identity.User{ID:"owner"}},Authorizer:fakeAuthz{allowed:true,deleted:&deleted},Resources:fakeResources{deletedChange:&change},AuthorizationOutbox:fakeOutbox{}};if err:=a.DeleteResource(context.Background(),"Bearer valid","example","id");err!=nil{t.Fatal(err)};if change.Operation!=ports.AuthorizationDelete||change.ResourceID!="example/id"{t.Fatalf("unexpected cleanup change: %+v",change)};if deleted{t.Fatal("empty fake outbox should not directly delete a relationship")}}
func TestReconcileDeletesAuthorizationRelationship(t *testing.T){deleted:=false;completed:=false;a:=App{Authorizer:fakeAuthz{deleted:&deleted},AuthorizationOutbox:fakeOutbox{changes:[]ports.AuthorizationChange{{ID:"change",Operation:ports.AuthorizationDelete}},completed:&completed}};if err:=a.ReconcileAuthorization(context.Background(),1);err!=nil{t.Fatal(err)};if !deleted||!completed{t.Fatalf("deleted=%v completed=%v",deleted,completed)}}
