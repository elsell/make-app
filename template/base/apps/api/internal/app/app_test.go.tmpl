package app

import (
	"__MODULE__/apps/api/internal/domain/identity"
	"__MODULE__/apps/api/internal/ports"
	"context"
	"errors"
	"testing"
	"time"
)

type fakeClock struct{ now time.Time }

func (f fakeClock) Now() time.Time { return f.now }

type fakeAuth struct {
	claims ports.Claims
	err    error
}

func (f fakeAuth) Authenticate(context.Context, string) (ports.Claims, error) { return f.claims, f.err }

type fakeUsers struct {
	user identity.User
	err  error
}

func (f fakeUsers) ResolveOrCreate(context.Context, ports.Claims) (identity.User, error) {
	return f.user, f.err
}

type fakeAuthz struct {
	allowed bool
	err     error
	deleted *bool
}

func (f fakeAuthz) WriteOwner(context.Context, string, string, string) error { return f.err }
func (f fakeAuthz) DeleteOwner(context.Context, string, string, string) error {
	if f.deleted != nil {
		*f.deleted = true
	}
	return f.err
}
func (f fakeAuthz) Check(context.Context, string, string, string, string) (bool, error) {
	return f.allowed, f.err
}

type fakeResources struct {
	resource      ports.Resource
	page          ports.ResourcePage
	request       *ports.PageRequest
	deletedChange *ports.AuthorizationChange
}

func (f fakeResources) CreateResource(context.Context, ports.Resource, ports.AuthorizationChange) error {
	return nil
}
func (f fakeResources) ListResources(_ context.Context, _, _ string, p ports.PageRequest) (ports.ResourcePage, error) {
	if f.request != nil {
		*f.request = p
	}
	return f.page, nil
}
func (f fakeResources) GetResource(context.Context, string, string) (ports.Resource, error) {
	return f.resource, nil
}
func (f fakeResources) UpdateResource(_ context.Context, _, _, name string) (ports.Resource, error) {
	r := f.resource
	r.Name = name
	return r, nil
}
func (f fakeResources) DeleteResource(_ context.Context, _, _ string, c ports.AuthorizationChange) error {
	if f.deletedChange != nil {
		*f.deletedChange = c
	}
	return nil
}

type fakeOutbox struct {
	changes   []ports.AuthorizationChange
	completed *bool
	failed    *bool
}

func (f fakeOutbox) ClaimAuthorizationChanges(context.Context, string, time.Time, time.Duration, int) ([]ports.AuthorizationChange, error) {
	return f.changes, nil
}
func (f fakeOutbox) ClaimAuthorizationChange(context.Context, string, string, time.Time, time.Duration) (ports.AuthorizationChange, error) {
	if len(f.changes) == 0 {
		return ports.AuthorizationChange{}, ports.ErrNotFound
	}
	return f.changes[0], nil
}
func (f fakeOutbox) CompleteAuthorizationChange(context.Context, string, string, time.Time) error {
	if f.completed != nil {
		*f.completed = true
	}
	return nil
}
func (f fakeOutbox) FailAuthorizationChange(context.Context, string, string) error {
	if f.failed != nil {
		*f.failed = true
	}
	return nil
}
func TestGetResourceFailsClosed(t *testing.T) {
	a := App{Auth: fakeAuth{}, Users: fakeUsers{user: identity.User{ID: "attacker"}}, Authorizer: fakeAuthz{allowed: false}, Resources: fakeResources{resource: ports.Resource{ID: "secret", OwnerUserID: "owner"}}}
	_, err := a.GetResource(context.Background(), "Bearer token", "example", "secret")
	if !errors.Is(err, ErrForbidden) {
		t.Fatalf("expected forbidden, got %v", err)
	}
}
func TestGetResourceAllowsOwner(t *testing.T) {
	r := ports.Resource{ID: "mine", Domain: "example", OwnerUserID: "owner"}
	a := App{Auth: fakeAuth{}, Users: fakeUsers{user: identity.User{ID: "owner"}}, Authorizer: fakeAuthz{allowed: true}, Resources: fakeResources{resource: r}}
	got, err := a.GetResource(context.Background(), "Bearer token", "example", "mine")
	if err != nil || got.ID != "mine" {
		t.Fatalf("unexpected result: %#v %v", got, err)
	}
}
func TestReconcileKeepsFailedAuthorizationChangePending(t *testing.T) {
	failed := false
	a := App{Clock: fakeClock{}, Authorizer: fakeAuthz{err: errors.New("spicedb unavailable")}, AuthorizationOutbox: fakeOutbox{changes: []ports.AuthorizationChange{{ID: "change", ResourceID: "resource", SubjectID: "user", Operation: ports.AuthorizationTouch}}, failed: &failed}}
	if err := a.ReconcileAuthorization(context.Background(), "worker", 10); err == nil {
		t.Fatal("expected dependency error")
	}
	if !failed {
		t.Fatal("expected failed attempt to remain retryable")
	}
}
func TestReconcileCompletesSuccessfulAuthorizationChange(t *testing.T) {
	completed := false
	a := App{Clock: fakeClock{}, Authorizer: fakeAuthz{}, AuthorizationOutbox: fakeOutbox{changes: []ports.AuthorizationChange{{ID: "change", ResourceID: "resource", SubjectID: "user", Operation: ports.AuthorizationTouch}}, completed: &completed}}
	if err := a.ReconcileAuthorization(context.Background(), "worker", 10); err != nil {
		t.Fatal(err)
	}
	if !completed {
		t.Fatal("expected completed authorization change")
	}
}
func TestCurrentUserClassifiesOnlyTokenFailuresAsUnauthenticated(t *testing.T) {
	a := App{Auth: fakeAuth{err: errors.New("bad token")}, Users: fakeUsers{}}
	_, err := a.CurrentUser(context.Background(), "Bearer bad")
	if !errors.Is(err, ErrUnauthenticated) {
		t.Fatalf("expected unauthenticated, got %v", err)
	}
	databaseErr := errors.New("database unavailable")
	a = App{Auth: fakeAuth{}, Users: fakeUsers{err: databaseErr}}
	_, err = a.CurrentUser(context.Background(), "Bearer valid")
	if !errors.Is(err, databaseErr) || errors.Is(err, ErrUnauthenticated) {
		t.Fatalf("persistence error was misclassified: %v", err)
	}
}
func TestGetResourcePreservesAuthorizationDependencyFailure(t *testing.T) {
	dependencyErr := errors.New("spicedb unavailable")
	a := App{Auth: fakeAuth{}, Users: fakeUsers{user: identity.User{ID: "owner"}}, Authorizer: fakeAuthz{err: dependencyErr}}
	_, err := a.GetResource(context.Background(), "Bearer valid", "example", "id")
	if !errors.Is(err, dependencyErr) || errors.Is(err, ErrForbidden) {
		t.Fatalf("dependency failure was concealed as denial: %v", err)
	}
}
func TestDeleteResourceCompletesAuthorizationCleanupBeforeSuccess(t *testing.T) {
	var change ports.AuthorizationChange
	deleted := false
	completed := false
	queued := ports.AuthorizationChange{ID: "change", Operation: ports.AuthorizationDelete}
	a := App{Clock: fakeClock{}, Auth: fakeAuth{}, Users: fakeUsers{user: identity.User{ID: "owner"}}, Authorizer: fakeAuthz{allowed: true, deleted: &deleted}, Resources: fakeResources{deletedChange: &change}, AuthorizationOutbox: fakeOutbox{changes: []ports.AuthorizationChange{queued}, completed: &completed}}
	if err := a.DeleteResource(context.Background(), "Bearer valid", "example", "id"); err != nil {
		t.Fatal(err)
	}
	if change.Operation != ports.AuthorizationDelete || change.ResourceID != "example/id" {
		t.Fatalf("unexpected cleanup change: %+v", change)
	}
	if !deleted || !completed {
		t.Fatalf("delete returned before authorization cleanup: deleted=%v completed=%v", deleted, completed)
	}
}
func TestListResourcesUsesBoundedOpaqueCursor(t *testing.T) {
	request := ports.PageRequest{}
	a := App{Auth: fakeAuth{}, Users: fakeUsers{user: identity.User{ID: "owner"}}, Resources: fakeResources{request: &request, page: ports.ResourcePage{Resources: []ports.Resource{{ID: "second"}}, HasMore: true}}}
	page, err := a.ListResources(context.Background(), "Bearer valid", "example", "Zmlyc3Q", 2)
	if err != nil {
		t.Fatal(err)
	}
	if request.AfterID != "first" || request.Limit != 2 {
		t.Fatalf("unexpected page request: %+v", request)
	}
	if page.NextCursor != "c2Vjb25k" {
		t.Fatalf("unexpected cursor %q", page.NextCursor)
	}
	if _, err := a.ListResources(context.Background(), "Bearer valid", "example", "%%%", 2); !errors.Is(err, ports.ErrInvalidArgument) {
		t.Fatal("malformed cursor accepted")
	}
	if _, err := a.ListResources(context.Background(), "Bearer valid", "example", "", 101); !errors.Is(err, ports.ErrInvalidArgument) {
		t.Fatal("oversized page accepted")
	}
}
func TestReconcileDeletesAuthorizationRelationship(t *testing.T) {
	deleted := false
	completed := false
	a := App{Clock: fakeClock{}, Authorizer: fakeAuthz{deleted: &deleted}, AuthorizationOutbox: fakeOutbox{changes: []ports.AuthorizationChange{{ID: "change", Operation: ports.AuthorizationDelete}}, completed: &completed}}
	if err := a.ReconcileAuthorization(context.Background(), "worker", 1); err != nil {
		t.Fatal(err)
	}
	if !deleted || !completed {
		t.Fatalf("deleted=%v completed=%v", deleted, completed)
	}
}
