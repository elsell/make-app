package httpserver

import (
	"context"
	"net/http"
	"github.com/danielgtaylor/huma/v2"
	"github.com/danielgtaylor/huma/v2/adapters/humago"
	"__MODULE__/apps/api/internal/app"
)

type MeInput struct { Authorization string `header:"Authorization" required:"true"` }
type UserDTO struct { ID string `json:"id"`; Email string `json:"email"`; DisplayName string `json:"displayName"` }
type MeOutput struct { Body struct { Data UserDTO `json:"data"` } }
type ResourceDTO struct { ID string `json:"id"`; Name string `json:"name"` }
type CreateResourceInput struct { Authorization string `header:"Authorization" required:"true"`; Body struct{Name string `json:"name" minLength:"1"`} }
type ResourcePathInput struct { Authorization string `header:"Authorization" required:"true"`; ID string `path:"id"` }
type ResourceOutput struct { Body struct{Data ResourceDTO `json:"data"`} }
type ResourceListOutput struct { Body struct{Data []ResourceDTO `json:"data"`} }

func New(application app.App) (http.Handler, huma.API) {
	mux:=http.NewServeMux(); config:=huma.DefaultConfig("__APP_NAME__ API","1.0.0"); config.Components.SecuritySchemes=map[string]*huma.SecurityScheme{"oidc":{Type:"openIdConnect",OpenIDConnectURL:"/.well-known/openid-configuration"}}
	api:=humago.New(mux,config)
	huma.Register(api,huma.Operation{OperationID:"get-me",Method:http.MethodGet,Path:"/v1/me",Summary:"Get current user",Security:[]map[string][]string{{"oidc":{}}}},func(ctx context.Context,input *MeInput)(*MeOutput,error){ u,err:=application.CurrentUser(ctx,input.Authorization); if err!=nil{return nil,huma.Error401Unauthorized("authentication required")}; out:=&MeOutput{}; out.Body.Data=UserDTO{ID:u.ID,Email:u.Email,DisplayName:u.DisplayName}; return out,nil })
	huma.Register(api,huma.Operation{OperationID:"create-example",Method:http.MethodPost,Path:"/v1/examples",Security:[]map[string][]string{{"oidc":{}}}},func(ctx context.Context,input *CreateResourceInput)(*ResourceOutput,error){r,err:=application.CreateResource(ctx,input.Authorization,input.Body.Name);if err!=nil{return nil,huma.Error401Unauthorized("authentication required")};out:=&ResourceOutput{};out.Body.Data=ResourceDTO{ID:r.ID,Name:r.Name};return out,nil})
	huma.Register(api,huma.Operation{OperationID:"list-examples",Method:http.MethodGet,Path:"/v1/examples",Security:[]map[string][]string{{"oidc":{}}}},func(ctx context.Context,input *MeInput)(*ResourceListOutput,error){rows,err:=application.ListResources(ctx,input.Authorization);if err!=nil{return nil,huma.Error401Unauthorized("authentication required")};out:=&ResourceListOutput{};for _,r:=range rows{out.Body.Data=append(out.Body.Data,ResourceDTO{ID:r.ID,Name:r.Name})};return out,nil})
	huma.Register(api,huma.Operation{OperationID:"get-example",Method:http.MethodGet,Path:"/v1/examples/{id}",Security:[]map[string][]string{{"oidc":{}}}},func(ctx context.Context,input *ResourcePathInput)(*ResourceOutput,error){r,err:=application.GetResource(ctx,input.Authorization,input.ID);if err!=nil{return nil,huma.Error404NotFound("not found")};out:=&ResourceOutput{};out.Body.Data=ResourceDTO{ID:r.ID,Name:r.Name};return out,nil})
	mux.HandleFunc("GET /healthz",func(w http.ResponseWriter,r *http.Request){w.WriteHeader(http.StatusNoContent)})
	return withCORS(mux),api
}
func withCORS(next http.Handler)http.Handler{return http.HandlerFunc(func(w http.ResponseWriter,r *http.Request){origin:=r.Header.Get("Origin");if origin=="http://localhost:5173"{w.Header().Set("Access-Control-Allow-Origin",origin);w.Header().Set("Access-Control-Allow-Headers","Authorization, Content-Type");w.Header().Set("Access-Control-Allow-Methods","GET, POST, PATCH, DELETE, OPTIONS");w.Header().Add("Vary","Origin")};if r.Method==http.MethodOptions{if origin!="http://localhost:5173"{http.Error(w,"forbidden",http.StatusForbidden);return};w.WriteHeader(http.StatusNoContent);return};next.ServeHTTP(w,r)})}
