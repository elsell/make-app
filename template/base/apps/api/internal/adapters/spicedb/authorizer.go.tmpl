package spicedb

import (
	"__MODULE__/apps/api/internal/ports"
	"context"
	"crypto/tls"
	"errors"
	v1 "github.com/authzed/authzed-go/proto/authzed/api/v1"
	"github.com/authzed/authzed-go/v1"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials"
	"google.golang.org/grpc/credentials/insecure"
	"sort"
	"strings"
)

const RequiredSchema = `definition user {}
definition resource {
  relation owner: user
  permission view = owner
  permission update = owner
  permission delete = owner
}`

type Authorizer struct{ client *authzed.Client }
type tokenCredentials struct{ token string }

func (t tokenCredentials) GetRequestMetadata(context.Context, ...string) (map[string]string, error) {
	return map[string]string{"authorization": "Bearer " + t.token}, nil
}
func (tokenCredentials) RequireTransportSecurity() bool { return false }
func New(endpoint, token string, insecureTransport bool) (*Authorizer, error) {
	transport := grpc.WithTransportCredentials(credentials.NewTLS(&tls.Config{MinVersion: tls.VersionTLS12}))
	if insecureTransport {
		transport = grpc.WithTransportCredentials(insecure.NewCredentials())
	}
	options := []grpc.DialOption{transport}
	if token != "" {
		options = append(options, grpc.WithPerRPCCredentials(tokenCredentials{token: token}))
	}
	c, err := authzed.NewClient(endpoint, options...)
	if err != nil {
		return nil, err
	}
	return &Authorizer{client: c}, nil
}
func (a *Authorizer) WriteSchema(ctx context.Context, schema string) error {
	_, err := a.client.WriteSchema(ctx, &v1.WriteSchemaRequest{Schema: schema})
	return err
}
func (a *Authorizer) Health(ctx context.Context) error {
	response, err := a.client.ReadSchema(ctx, &v1.ReadSchemaRequest{})
	if err != nil {
		return err
	}
	if !schemaCurrent(response.SchemaText) {
		return errors.New("SpiceDB schema is not current")
	}
	return nil
}
func schemaCurrent(schema string) bool {
	return canonicalSchema(schema) == canonicalSchema(RequiredSchema)
}
func canonicalSchema(schema string) string {
	fields := strings.Fields(schema)
	var definitions []string
	for start := 0; start < len(fields); {
		if fields[start] != "definition" {
			return ""
		}
		end := start + 1
		for end < len(fields) && fields[end] != "definition" {
			end++
		}
		definitions = append(definitions, strings.Join(fields[start:end], " "))
		start = end
	}
	sort.Strings(definitions)
	return strings.Join(definitions, "\n")
}
func (a *Authorizer) WriteOwner(ctx context.Context, resourceType, resourceID, userID string) error {
	_, err := a.client.WriteRelationships(ctx, &v1.WriteRelationshipsRequest{Updates: []*v1.RelationshipUpdate{{Operation: v1.RelationshipUpdate_OPERATION_TOUCH, Relationship: &v1.Relationship{Resource: &v1.ObjectReference{ObjectType: resourceType, ObjectId: resourceID}, Relation: "owner", Subject: &v1.SubjectReference{Object: &v1.ObjectReference{ObjectType: "user", ObjectId: userID}}}}}})
	return err
}
func (a *Authorizer) DeleteOwner(ctx context.Context, resourceType, resourceID, userID string) error {
	_, err := a.client.WriteRelationships(ctx, &v1.WriteRelationshipsRequest{Updates: []*v1.RelationshipUpdate{{Operation: v1.RelationshipUpdate_OPERATION_DELETE, Relationship: &v1.Relationship{Resource: &v1.ObjectReference{ObjectType: resourceType, ObjectId: resourceID}, Relation: "owner", Subject: &v1.SubjectReference{Object: &v1.ObjectReference{ObjectType: "user", ObjectId: userID}}}}}})
	return err
}
func (a *Authorizer) Check(ctx context.Context, resourceType, resourceID, permission, userID string) (bool, error) {
	r, err := a.client.CheckPermission(ctx, &v1.CheckPermissionRequest{Resource: &v1.ObjectReference{ObjectType: resourceType, ObjectId: resourceID}, Permission: permission, Subject: &v1.SubjectReference{Object: &v1.ObjectReference{ObjectType: "user", ObjectId: userID}}, Consistency: &v1.Consistency{Requirement: &v1.Consistency_FullyConsistent{FullyConsistent: true}}})
	if err != nil {
		return false, err
	}
	return r.Permissionship == v1.CheckPermissionResponse_PERMISSIONSHIP_HAS_PERMISSION, nil
}

var _ ports.Authorizer = (*Authorizer)(nil)
