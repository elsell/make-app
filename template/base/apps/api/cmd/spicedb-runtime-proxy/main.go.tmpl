package main

import (
	"context"
	"crypto/tls"
	"log/slog"
	"net"
	"os"
	"strconv"

	"__MODULE__/apps/api/internal/adapters/spicedbproxy"
	"github.com/authzed/authzed-go/v1"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials"
	"google.golang.org/grpc/credentials/insecure"
)

type tokenCredentials struct{ token string }
func (t tokenCredentials) GetRequestMetadata(context.Context, ...string) (map[string]string, error) { return map[string]string{"authorization": "Bearer " + t.token}, nil }
func (tokenCredentials) RequireTransportSecurity() bool { return false }

func main() {
	listenAddress := os.Getenv("__ENV_PREFIX___SPICEDB_PROXY_ADDR")
	endpoint := os.Getenv("__ENV_PREFIX___SPICEDB_UPSTREAM_ENDPOINT")
	adminToken := os.Getenv("__ENV_PREFIX___SPICEDB_SCHEMA_TOKEN")
	runtimeToken := os.Getenv("__ENV_PREFIX___SPICEDB_TOKEN")
	insecureTransport, parseErr := strconv.ParseBool(os.Getenv("__ENV_PREFIX___SPICEDB_INSECURE"))
	if listenAddress == "" || endpoint == "" || adminToken == "" || runtimeToken == "" || adminToken == runtimeToken || parseErr != nil {
		slog.Error("SpiceDB runtime proxy configuration invalid")
		os.Exit(1)
	}
	transport := grpc.WithTransportCredentials(credentials.NewTLS(&tls.Config{MinVersion: tls.VersionTLS12}))
	if insecureTransport { transport = grpc.WithTransportCredentials(insecure.NewCredentials()) }
	upstream, err := authzed.NewClient(endpoint, transport, grpc.WithPerRPCCredentials(tokenCredentials{token: adminToken}))
	if err != nil { slog.Error("SpiceDB proxy upstream failed", "error", err); os.Exit(1) }
	listener, err := net.Listen("tcp", listenAddress)
	if err != nil { slog.Error("SpiceDB proxy listen failed", "error", err); os.Exit(1) }
	server := grpc.NewServer(grpc.UnaryInterceptor(spicedbproxy.Authenticate(runtimeToken)))
	spicedbproxy.New(upstream.PermissionsServiceClient, upstream.SchemaServiceClient).Register(server)
	if err := server.Serve(listener); err != nil { slog.Error("SpiceDB proxy stopped", "error", err); os.Exit(1) }
}
