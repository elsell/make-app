package main

import (
	"context"
	"log/slog"
	"net/http"
	"os"
	"os/signal"
	"time"
	"__MODULE__/apps/api/internal/adapters/gormstore"
	"__MODULE__/apps/api/internal/adapters/httpserver"
	"__MODULE__/apps/api/internal/adapters/oidcauth"
	spice "__MODULE__/apps/api/internal/adapters/spicedb"
	"__MODULE__/apps/api/internal/app"
	"__MODULE__/apps/api/internal/config"
	"__MODULE__/apps/api/internal/generated"
)
const authorizationSchema=`definition user {}
definition resource {
  relation owner: user
  permission view = owner
  permission update = owner
  permission delete = owner
}`
func main(){ctx,stop:=signal.NotifyContext(context.Background(),os.Interrupt);defer stop();cfg,err:=config.Load();if err!=nil{slog.Error("configuration invalid","error",err);os.Exit(1)};store,err:=gormstore.Open("postgres",cfg.DatabaseDSN);if err!=nil{panic(err)};auth,err:=oidcauth.New(ctx,cfg.OIDCIssuer,cfg.OIDCAudience);if err!=nil{panic(err)};authorizer,err:=spice.New(cfg.SpiceDBEndpoint,cfg.SpiceDBToken);if err!=nil{panic(err)};if err=authorizer.WriteSchema(ctx,authorizationSchema);err!=nil{panic(err)};application:=app.App{Auth:auth,Users:store,Authorizer:authorizer,Resources:store,AuthorizationOutbox:store};go reconcile(ctx,application);handler,_:=httpserver.New(application,generated.Domains);server:=&http.Server{Addr:cfg.HTTPAddr,Handler:handler};go func(){<-ctx.Done();_ = server.Shutdown(context.Background())}();if err:=server.ListenAndServe();err!=nil&&err!=http.ErrServerClosed{panic(err)}}
func reconcile(ctx context.Context,application app.App){ticker:=time.NewTicker(time.Second);defer ticker.Stop();for{_ = application.ReconcileAuthorization(ctx,25);select{case<-ctx.Done():return;case<-ticker.C:}}}
