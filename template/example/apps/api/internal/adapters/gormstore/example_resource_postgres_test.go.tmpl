package gormstore

import (
	"context"
	"errors"
	"testing"
	"time"

	"__MODULE__/apps/api/internal/domain/audit"
	"__MODULE__/apps/api/internal/ports"
)

func TestExampleResourceMutationsRequireCoherentAudit(t *testing.T) {
	if *postgresTestDSN == "" {
		t.Skip("-database-dsn is required for PostgreSQL integration")
	}
	store, err := Open("postgres", *postgresTestDSN)
	if err != nil {
		t.Fatal(err)
	}
	ctx := context.Background()
	tx := store.DB.WithContext(ctx).Begin()
	if tx.Error != nil {
		t.Fatal(tx.Error)
	}
	t.Cleanup(func() { _ = tx.Rollback().Error })
	now := time.Now().UTC()
	if err := tx.Create(&userModel{ID: "audit-owner", CreatedAt: now, UpdatedAt: now}).Error; err != nil {
		t.Fatal(err)
	}
	txStore := &Store{DB: tx}
	resource := ports.Resource{ID: "unaudited-resource", Domain: "example", OwnerUserID: "audit-owner", Name: "Walk", CreatedAt: now}
	change := ports.AuthorizationChange{ID: "unaudited-change", ResourceType: "resource", ResourceID: "example/unaudited-resource", Relation: "owner", SubjectType: "user", SubjectID: "audit-owner", Operation: ports.AuthorizationTouch, LockedBy: "worker", Lease: time.Minute}
	mismatched := audit.Event{ID: "mismatched-event", OwnerUserID: "audit-owner", ActorUserID: "audit-owner", Action: audit.ResourceViewed, TargetType: resource.Domain, TargetID: resource.ID, Outcome: audit.Succeeded, CorrelationID: "request-id", OccurredAt: now}
	if _, _, err := txStore.CreateResource(ctx, resource, change, mismatched, ports.Idempotency{PrincipalID: resource.OwnerUserID, Operation: "resource.create:example", Key: "request-key-0001", RequestHash: make([]byte, 32)}); !errors.Is(err, ports.ErrInvalidArgument) {
		t.Fatalf("invalid audit did not reject mutation: %v", err)
	}
	var resourceCount int64
	if err := tx.Model(&resourceModel{}).Where("id = ?", resource.ID).Count(&resourceCount).Error; err != nil || resourceCount != 0 {
		t.Fatalf("resource committed without audit: count=%d err=%v", resourceCount, err)
	}
	createdAudit := mismatched
	createdAudit.ID, createdAudit.Action = "created-event", audit.ResourceCreated
	if _, _, err := txStore.CreateResource(ctx, resource, change, createdAudit, ports.Idempotency{PrincipalID: resource.OwnerUserID, Operation: "resource.create:example", Key: "request-key-0002", RequestHash: make([]byte, 32)}); err != nil {
		t.Fatal(err)
	}
	var createdAuditCount int64
	if err := tx.Model(&auditEventModel{}).Where("id = ? AND action = ?", createdAudit.ID, audit.ResourceCreated).Count(&createdAuditCount).Error; err != nil || createdAuditCount != 1 {
		t.Fatalf("resource create audit did not commit atomically: count=%d err=%v", createdAuditCount, err)
	}
	wrongUpdate := createdAudit
	wrongUpdate.ID, wrongUpdate.Action, wrongUpdate.TargetID = "wrong-update", audit.ResourceUpdated, "other-resource"
	if _, err := txStore.UpdateResource(ctx, resource.Domain, resource.ID, "Changed", wrongUpdate); !errors.Is(err, ports.ErrInvalidArgument) {
		t.Fatalf("mismatched update audit accepted: %v", err)
	}
	unchanged, err := txStore.GetResource(ctx, resource.Domain, resource.ID)
	if err != nil || unchanged.Name != resource.Name {
		t.Fatalf("update committed without coherent audit: %+v %v", unchanged, err)
	}
	wrongDelete := createdAudit
	wrongDelete.ID, wrongDelete.Action, wrongDelete.OwnerUserID = "wrong-delete", audit.ResourceDeleted, "audit-actor"
	deleteChange := change
	deleteChange.ID = "delete-change"
	if err := txStore.DeleteResource(ctx, resource.Domain, resource.ID, deleteChange, wrongDelete); !errors.Is(err, ports.ErrInvalidArgument) {
		t.Fatalf("mismatched delete audit accepted: %v", err)
	}
	if _, err := txStore.GetResource(ctx, resource.Domain, resource.ID); err != nil {
		t.Fatalf("delete committed without coherent audit: %v", err)
	}
}
